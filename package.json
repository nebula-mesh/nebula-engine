{
  "name": "nebula-engine",
  "version": "1.6.0",
  "description": "基于Hono的轻量级微服务引擎框架",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "build:all": "pnpm -r build",
    "docs:dev": "pnpm --filter nebula-engine-docs dev",
    "docs:build": "pnpm --filter nebula-engine-docs build",
    "dev": "tsx tests/integration/start-service.ts",
    "test": "pnpm --filter nebula-client build && vitest --run",
    "test:all": "pnpm -r test",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --run --coverage",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "microservice",
    "hono",
    "framework",
    "typescript"
  ],
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "author": "",
  "private": true,
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@hono/otel": "^1.1.2",
    "@opentelemetry/api": "^1",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "ejson": "^2.2.3",
    "etcd3": "^1.1.2",
    "hono": "^4.12.26",
    "nanoid": "^5.1.15",
    "prettier": "^3.8.4",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1",
    "@types/ejson": "^2.2.2",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "ioredis": "^5.11.1",
    "nebula-client": "workspace:*",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1"
  }
}
