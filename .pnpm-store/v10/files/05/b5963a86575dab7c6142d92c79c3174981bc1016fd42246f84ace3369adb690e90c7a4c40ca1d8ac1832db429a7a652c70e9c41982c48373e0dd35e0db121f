{
  "name": "imean-service-client",
  "version": "1.6.0",
  "description": "Universal client for imean-service-engine",
  "keywords": [
    "microservice",
    "websocket",
    "http",
    "client",
    "node"
  ],
  "author": "imean",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://git.imean.tech/imean/imean-microservice-framework.git"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "coverage": "vitest --coverage",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "brotli-wasm": "^3.0.1",
    "dayjs": "1.11.13",
    "ejson": "^2.2.3",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.x"
  },
  "devDependencies": {
    "@types/ejson": "^2.2.2",
    "@types/node": "^20.0.0",
    "imean-service-engine": "^1.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.7.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.3"
  },
  "engines": {
    "node": ">=16"
  }
}
